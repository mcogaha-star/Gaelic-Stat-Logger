    "away_team_id": {
      "type": "string"
    },
    "opponent": {
      "type": "string",
      "description": "Legacy: opposition team name"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "venue": {
      "type": "string"
    },
    "competition": {
