{
  "name": "StatEntry",
  "type": "object",
  "properties": {
    "match_id": {
      "type": "string"
    },
    "stat_type": {
      "type": "string"
    },
    "play_id": { "type": "number" },
    "possession_id": { "type": "number" },
    "possession_team_side": { "type": "string" },
    "team_side": { "type": "string" },
    "counter_attack": { "type": "boolean", "default": false },
    "player_name": { "type": "string" },
    "player_number": { "type": "number" },
    "recipient_name": { "type": "string" },
    "recipient_number": { "type": "number" },
    "raw_x_position": { "type": "number" },
    "raw_y_position": { "type": "number" },
    "raw_end_x_position": { "type": "number" },
    "raw_end_y_position": { "type": "number" },
    "x_position": { "type": "number" },
    "y_position": { "type": "number" },
    "end_x_position": { "type": "number" },
    "end_y_position": { "type": "number" },
    "time_s": { "type": "number" },
    "normalized_time_s": { "type": "number" },
    "is_pass": {
      "type": "boolean",
      "default": false
    },
    "half": {
      "type": "string",
      "enum": [
        "first",
        "second",
        "et_first",
        "et_second"
      ]
    },
    "timestamp": {
      "type": "string"
    },
    "extra_data": {
      "type": "string",
      "description": "JSON string containing all sub-menu field values"
    }
  },
  "required": [
    "match_id",
    "stat_type"
  ]
}
